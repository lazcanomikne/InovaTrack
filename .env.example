# ── Base de datos (Turso / libSQL) ──────────────────────────────────────────
# Crea una base NUEVA para InovaTrack (no reuses la de InovaOS):
#   turso db create inovatrack
#   turso db show inovatrack --url
#   turso db tokens create inovatrack
TURSO_DATABASE_URL=libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=tu-token

# ── Sesión ──────────────────────────────────────────────────────────────────
# Firma los JWT de sesión y el HMAC de los códigos OTP. Genera uno nuevo con:
#   openssl rand -base64 32
AUTH_SECRET=

# ── Correo (SMTP) — códigos de acceso y avisos ──────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Notificaciones push (VAPID) ─────────────────────────────────────────────
# Genera un par NUEVO con:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@inovatech.com.mx

# ── Archivos adjuntos (Vercel Blob) ─────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Passkeys / WebAuthn ─────────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=InovaTrack
WEBAUTHN_ORIGIN=http://localhost:5173

# ── Opcional: acceso server-to-server (X-Service-Token + X-Actor-Email) ─────
SERVICE_TOKEN=
